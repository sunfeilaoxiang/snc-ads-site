---
/**
 * Contact page — the audit-request form.
 *
 * The form posts to Web3Forms (https://web3forms.com) — a static-site form
 * backend. It works on GitHub Pages with no server.
 *
 * Web3Forms key is wired (2026-05-19). Submissions arrive at the email
 * registered with the Web3Forms account (demetrius.sokolovs@gmail.com).
 * To rotate the key, replace it below AND in src/pages/en/contact.astro —
 * both pages must carry the same key.
 *
 * The audit is qualify-gated (Operations Bible §3.4): this form is the hook,
 * not an instant free audit. Copy reflects that — do not promise otherwise.
 */
import Base from '../layouts/Base.astro';
import { url } from '../lib/links';

const WEB3FORMS_ACCESS_KEY = 'acd1f7f4-6610-45b3-a0fb-4bf078dd6ef7';
const thankYouUrl = new URL(url('/thank-you'), Astro.site).href;

const steps = [
  'Вы оставляете заявку — пару минут.',
  'Мы задаём несколько уточняющих вопросов письменно — короткий скрининг.',
  'Если подходим друг другу — разбираем ваш рекламный аккаунт и присылаем письменный отчёт.',
  'Если не подходим — говорим сразу и честно, без «продаж». По возможности подскажем, к кому обратиться.',
];
---

<Base
  title="Контакт — SNC Advertising | Получить аудит"
  description="Оставьте заявку на бесплатный разбор вашего рекламного аккаунта в Meta. Короткий скрининг, затем детальный письменный разбор — если мы подходим друг другу."
>
  <section class="page-hero">
    <div class="page-hero-label">Контакт</div>
    <h1 class="page-hero-h1">Получить аудит.</h1>
    <p class="page-hero-lede">
      Оставьте заявку. Зададим несколько вопросов, чтобы понять, подходим ли друг
      другу. Если да — разберём ваш рекламный аккаунт. Если нет — скажем сразу.
    </p>
  </section>

  <!-- Форма -->
  <section class="section section-dark">
    <div class="sec-label on-dark">Заявка</div>

    <form id="audit-form" class="form" action="https://api.web3forms.com/submit" method="POST" data-redirect={thankYouUrl}>
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
      <input type="hidden" name="redirect" value={thankYouUrl} />
      <input type="hidden" name="subject" value="Новая заявка на аудит — SNC Advertising" />
      <input type="hidden" name="from_name" value="SNC Advertising — сайт" />
      <!-- Attribution — populated client-side from sessionStorage (first-touch) -->
      <input type="hidden" name="utm_source" />
      <input type="hidden" name="utm_medium" />
      <input type="hidden" name="utm_campaign" />
      <input type="hidden" name="utm_term" />
      <input type="hidden" name="utm_content" />
      <input type="hidden" name="fbclid" />
      <input type="hidden" name="gclid" />
      <input type="hidden" name="landing_page" />
      <input type="hidden" name="referrer" />
      <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

      <div class="field">
        <label for="name">Имя</label>
        <input id="name" name="name" type="text" required autocomplete="name" />
      </div>

      <div class="row">
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="telegram">Telegram <span class="opt">— по желанию</span></label>
          <input id="telegram" name="telegram" type="text" placeholder="@username" />
        </div>
      </div>

      <div class="field">
        <label for="company">Сайт или бренд</label>
        <input id="company" name="company" type="text" required placeholder="example.com" />
        <p style="margin-top:6px;font-size:11px;color:var(--text-dim)">Чтобы посмотреть ваш аккаунт перед разбором.</p>
      </div>

      <div class="field">
        <label class="field-label">Тип бизнеса</label>
        <div class="chips" role="radiogroup" aria-label="Тип бизнеса">
          <label class="chip"><input type="radio" name="business_type" value="Ecommerce" required /><span>Ecommerce</span></label>
          <label class="chip"><input type="radio" name="business_type" value="Lead-gen / услуги" /><span>Lead-gen / услуги</span></label>
          <label class="chip"><input type="radio" name="business_type" value="Другое" /><span>Другое</span></label>
        </div>
      </div>

      <div class="field">
        <label class="field-label">Бюджет на рекламу в месяц</label>
        <p style="margin:2px 0 10px;font-size:11px;color:var(--text-dim)">Помогает понять, сможем ли быть полезны.</p>
        <div class="chips" role="radiogroup" aria-label="Бюджет на рекламу в месяц">
          <label class="chip"><input type="radio" name="ad_budget" value="До €1 000" required /><span>До €1 000</span></label>
          <label class="chip"><input type="radio" name="ad_budget" value="€1 000 – 3 000" /><span>€1 000 – 3 000</span></label>
          <label class="chip"><input type="radio" name="ad_budget" value="€3 000 – 10 000" /><span>€3 000 – 10 000</span></label>
          <label class="chip"><input type="radio" name="ad_budget" value="Более €10 000" /><span>Более €10 000</span></label>
        </div>
      </div>

      <div class="field">
        <label for="message">Коротко о задаче <span class="opt">— по желанию</span></label>
        <textarea id="message" name="message" rows="4" placeholder="Что сейчас не так с рекламой, чего хотите достичь."></textarea>
      </div>

      <button type="submit" class="btn btn-on-white form-submit">Запросить разбор</button>
      <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
      <p style="margin-top:12px;font-size:12px;color:var(--text-dim)">Бесплатно · отвечаем в тот же день · без спама.</p>
    </form>
  </section>

  <!-- Что дальше -->
  <section class="section section-warm">
    <div class="sec-label">Что дальше</div>
    <ol class="next">
      {steps.map((s, i) => (
        <li class="next-item">
          <span class="next-n">{String(i + 1).padStart(2, '0')}</span>
          <span class="next-d muted-light">{s}</span>
        </li>
      ))}
    </ol>
  </section>

  <!-- Звонок напрямую -->
  <section class="section section-light">
    <div class="sec-label">Звонок напрямую</div>
    <h2 class="statement" style="margin-top:20px;max-width:640px;">
      Уже знаете, что хотите обсудить?
    </h2>
    <p class="lede muted-light" style="margin-top:16px;">
      Забронируйте 30 минут напрямую — разберём аккаунт и ответим на вопросы.
      Удобно, если вы уже на стадии принятия решения.
    </p>
    <div
      class="calendly-inline-widget"
      data-url="https://calendly.com/dmitrijs-sncads/30min?hide_gdpr_banner=1&primary_color=1e4d3a"
      style="min-width:320px;height:700px;margin-top:28px;"
    >
    </div>
    <script
      is:inline
      src="https://assets.calendly.com/assets/external/widget.js"
      async
    ></script>
  </section>

  <!-- Альтернатива -->
  <section class="section section-forest">
    <div class="sec-label on-dark">Прямая связь</div>
    <p class="lede muted-dark" style="margin-top:20px;">
      Не любите формы — напишите напрямую.
    </p>
    <div class="direct">
      <a class="direct-link" href="https://t.me/sunnfeii">Telegram &rarr;</a>
      <a class="direct-link" href="mailto:dmitrijs@sncads.com">dmitrijs@sncads.com &rarr;</a>
    </div>
  </section>
</Base>

<style>
  .form { margin-top: 28px; max-width: 640px; }
  .hp { position: absolute; left: -9999px; }

  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .field { margin-bottom: 20px; display: flex; flex-direction: column; }
  .field label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(255, 255, 255, 0.6);
    margin-bottom: 8px;
  }
  .opt { font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-dim); }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font);
    font-size: 13px;
    color: var(--white);
    background: #141414;
    border: 1px solid var(--dim);
    border-radius: 0;
    padding: 12px 14px;
    transition: border-color 0.15s;
  }
  .field textarea { resize: vertical; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none; border-color: var(--sage);
  }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--text-dim); }

  /* Selectable chips — minimalist replacement for the old dropdowns */
  .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { position: relative; display: inline-flex; cursor: pointer; }
  .chip input { position: absolute; inset: 0; margin: 0; opacity: 0; cursor: pointer; }
  .chip span {
    font-size: 13px; line-height: 1; color: rgba(255, 255, 255, 0.7);
    background: #141414; border: 1px solid var(--dim);
    padding: 11px 16px; user-select: none;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .chip:hover span { border-color: var(--sage); }
  .chip input:checked + span { background: var(--green); border-color: var(--green); color: var(--white); }
  .chip input:focus-visible + span { outline: 1px solid var(--sage); outline-offset: 2px; }

  .form-submit { margin-top: 4px; cursor: pointer; }
  .form-submit[disabled] { opacity: 0.5; cursor: default; }

  .form-status {
    margin-top: 16px; font-size: 12px; line-height: 1.6; min-height: 1em;
  }
  .form-status.ok  { color: var(--sage); }
  .form-status.err { color: var(--bronze); }

  .next { margin-top: 28px; max-width: 680px; }
  .next-item {
    display: flex; gap: 20px; align-items: baseline;
    padding: 16px 0; border-top: 1px solid var(--dim-light);
  }
  .next-item:last-child { border-bottom: 1px solid var(--dim-light); }
  .next-n { font-size: 13px; font-weight: 600; color: var(--bronze); flex-shrink: 0; }
  .next-d { font-size: 14px; line-height: 1.7; }

  .direct { margin-top: 20px; display: flex; gap: 32px; flex-wrap: wrap; }
  .direct-link {
    font-size: 14px; font-weight: 600; color: var(--sage);
    border-bottom: 1px solid transparent; transition: border-color 0.15s;
  }
  .direct-link:hover { border-bottom-color: var(--sage); }

  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; gap: 0; }
  }
</style>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');
  const submit = form?.querySelector('.form-submit') as HTMLButtonElement | null;

  // Populate attribution hidden fields: first-touch values from sessionStorage,
  // plus any params on the current URL (direct landing on /contact?utm=...).
  if (form) {
    try {
      const store = JSON.parse(sessionStorage.getItem('snc-attribution') || '{}');
      const qs = new URLSearchParams(window.location.search);
      ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'fbclid', 'gclid'].forEach((k) => {
        const v = qs.get(k) || store[k];
        const el = form.elements.namedItem(k) as HTMLInputElement | null;
        if (el && v) el.value = v;
      });
      const lp = form.elements.namedItem('landing_page') as HTMLInputElement | null;
      if (lp) lp.value = store.landing_page || window.location.pathname;
      const rf = form.elements.namedItem('referrer') as HTMLInputElement | null;
      if (rf) rf.value = store.referrer || document.referrer || '';
    } catch (e) {}
  }

  if (form && status && submit) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const key = (form.elements.namedItem('access_key') as HTMLInputElement)?.value;
      if (!key || key.startsWith('REPLACE_WITH')) {
        status.textContent =
          'Форма ещё не подключена. Напишите нам в Telegram или на email ниже.';
        status.className = 'form-status err';
        return;
      }

      status.textContent = '';
      status.className = 'form-status';
      submit.disabled = true;
      submit.textContent = 'Отправляем…';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        if (data.success) {
          // Redirect to the thank-you page (which fires the Lead conversion).
          const redirect = form.dataset.redirect;
          if (redirect) { window.location.href = redirect; return; }
          status.textContent =
            'Заявка отправлена. Ответим в течение одного рабочего дня.';
          status.className = 'form-status ok';
          submit.textContent = 'Отправлено';
        } else {
          throw new Error(data.message || 'submit failed');
        }
      } catch {
        status.textContent =
          'Не удалось отправить. Попробуйте ещё раз или напишите нам в Telegram.';
        status.className = 'form-status err';
        submit.disabled = false;
        submit.textContent = 'Запросить разбор';
      }
    });
  }
</script>
