---
/**
 * Tools index — Tool 1 (True ROAS Calculator) + Tool 2 (Meta Scorecard).
 * RU canonical. EN twin: src/pages/en/tools.astro.
 * Static page, no island — just two cards linking to the tools.
 */
import Base from '../layouts/Base.astro';
import { url } from '../lib/links';

const tools = [
  {
    n: '01',
    name: 'Калькулятор настоящего ROAS',
    desc: 'Meta показывает один ROAS. После себестоимости, доставки, возвратов и комиссий остаётся другой. Посчитайте безубыточный ROAS и реальную прибыль с рекламы за минуту.',
    href: url('/roas-calculator'),
    cta: 'Открыть калькулятор →',
  },
  {
    n: '02',
    name: 'Скоринг Meta-аккаунта',
    desc: '12 проверок, которые мы проводим перед тем, как взяться за аккаунт. Ответьте честно — получите оценку 0–100, разбор по слоям и список ваших слабых мест.',
    href: url('/meta-scorecard'),
    cta: 'Пройти скоринг →',
  },
];
---

<Base
  title="Инструменты — SNC Advertising"
  description="Бесплатные инструменты для владельцев ecommerce: калькулятор настоящего ROAS и скоринг Meta-аккаунта. Без регистрации, результат сразу."
>
  <section class="page-hero">
    <div class="page-hero-label">Инструменты</div>
    <h1 class="page-hero-h1">Бесплатные инструменты.</h1>
    <p class="page-hero-lede">
      Две быстрые проверки для владельцев ecommerce. Без регистрации, результат
      сразу. Если захотите — разберём аккаунт вручную.
    </p>
  </section>

  <section class="section section-dark">
    <div class="tools-grid">
      {
        tools.map((t) => (
          <a class="tool-card" href={t.href}>
            <span class="tool-n">{t.n}</span>
            <h2 class="tool-name">{t.name}</h2>
            <p class="tool-desc">{t.desc}</p>
            <span class="tool-cta">{t.cta}</span>
          </a>
        ))
      }
    </div>
  </section>
</Base>

<style>
  .tools-grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
    border: 1px solid var(--dim);
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.15s, background 0.15s;
  }
  .tool-card:hover {
    border-color: var(--sage);
    background: rgba(255, 255, 255, 0.04);
  }
  .tool-n {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--sage);
  }
  .tool-name {
    margin-top: 16px;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--white);
  }
  .tool-desc {
    margin-top: 14px;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.72);
    flex: 1;
  }
  .tool-cta {
    margin-top: 22px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
  }

  @media (max-width: 640px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
