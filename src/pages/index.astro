<script is:inline>
  /* Audit-teardown disclosure toggle.
     Native <button> + aria-expanded; vanilla JS only.
     Animation handled in CSS (transform on arrow, scale on press).
     Reduced-motion respected by the CSS layer.
  */
  (function () {
    var toggle = document.getElementById('razbor-toggle');
    var content = document.getElementById('razbor-content');
    if (!toggle || !content) return;

    toggle.addEventListener('click', function () {
      var open = toggle.getAttribute('aria-expanded') === 'true';
      var next = !open;
      toggle.setAttribute('aria-expanded', next ? 'true' : 'false');
      if (next) {
        content.hidden = false;
        // Move focus into the revealed region for keyboard users (first heading).
        var firstHeading = content.querySelector('h3');
        if (firstHeading) {
          firstHeading.setAttribute('tabindex', '-1');
          firstHeading.focus({ preventScroll: false });
        }
      } else {
        content.hidden = true;
        toggle.focus();
      }
    });
  })();
</script>
