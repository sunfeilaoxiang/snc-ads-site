---
/**
 * Home page — SNC Advertising.
 * Content source: ../../pages/01-home.md (the canonical copy reference).
 * Facts reconciled with ../../snc-media-ops/00_SNC_Media_Operations_Bible.md.
 */
import Base from '../layouts/Base.astro';
import { url } from '../lib/links';

/* A "what you get" strip — deliberate differentiators, not vanity metrics.
   Replaces the old stats strip, which quietly signalled "small and new". */
const principles = [
  { k: 'Meta',       v: 'один канал, отлаженный глубоко' },
  { k: 'Письменно',  v: 'отчётность и брифы — без лишних созвонов' },
  { k: 'С 1-го дня', v: 'живой дашборд и полный доступ к данным' },
  { k: '30 дней',    v: 'расторжение без штрафов и без вопросов' },
];

const services = [
  {
    name: 'Meta Ads — ecommerce',
    body: 'Запуск, тестирование креативов, оптимизация. Pixel/CAPI, каталоги, Advantage+ Shopping, ретаргет. Еженедельный письменный апдейт.',
  },
  {
    name: 'Meta Ads — lead-gen',
    body: 'Кампании на заявки для сервисных бизнесов. Цель — стоимость и качество лида, не клики. Прозрачная воронка от показа до заявки.',
  },
  {
    name: 'Креатив (опционально)',
    body: 'Бриф креативов под платформу. Координация с фрилансерами. Продакшн оплачивается клиентом отдельно, не входит в ретейнер.',
  },
];

const steps = [
  { n: '01', t: 'Аудит',                  d: '30 минут. Смотрим аккаунт, трекинг, креативы. По итогу — письменный отчёт и честный ответ: подходим друг другу или нет.' },
  { n: '02', t: 'Онбординг',              d: 'Доступы, бриф через шаблон, согласование бюджета и KPI. Запуск — в течение 14 дней.' },
  { n: '03', t: 'Ежедневная оптимизация', d: 'Тесты креативов, оптимизация бюджетов, масштабирование победителей. Без созвонов.' },
  { n: '04', t: 'Отчётность',             d: 'Дашборд в реальном времени. Письменный апдейт по пятницам. Стратегический созвон раз в месяц — по желанию клиента.' },
];

const fitYes = [
  'Ecommerce-бренд с годовым оборотом от €300k',
  'Бюджет на рекламу от €1k/мес, комфортный коридор — €3–10k/мес',
  'Готовы работать письменно, по шаблонам',
  'Хотят прозрачную отчётность с цифрами, не презентации',
  'Понимают, что результаты — функция качества продукта, креатива и бюджета, а не только агентства',
];

const fitNo = [
  'Ищут гарантии ROAS или количества лидов',
  'Бюджет на рекламу меньше €1k/мес',
  'Нужен ежедневный созвон и доступ в WhatsApp 24/7',
  'Хотят, чтобы агентство «придумало стратегию» вместо понимания собственного бизнеса',
  'Местный сервисный бизнес без онлайн-продаж (мы — про ecommerce)',
];

const founders = [
  {
    initial: 'Н',
    name: 'Никита',
    role: 'Meta / Delivery',
    body: '4 года ведения Meta Ads для ecommerce-брендов в EU. Отвечает за рекламную стратегию, исполнение, QA. До SNC — senior performance marketer в агентстве.',
  },
  {
    initial: 'Г',
    name: 'Гима',
    role: 'CCO / финансовая дисциплина',
    body: '5+ лет фрактального CFO для SMB и стартапов. Отвечает за коммерческую сторону, клиентские отношения, ценообразование, юнит-экономику.',
  },
];
---

<Base
  title="SNC Advertising — Performance-маркетинг для ecommerce-брендов"
  description="Senior-level Meta-реклама для ecommerce-фаундеров. Без лишних созвонов и агентского театра. Прозрачная письменная отчётность."
  ogTitle="SNC Advertising — Performance, без театра."
  ogDescription="Meta ads для ecommerce. Senior-исполнение, прозрачная отчётность, асинхронный формат работы."
>
  <!-- ══ 01 · HERO ══════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-top">
      <span class="hero-label">SNC Advertising &middot; Performance</span>
      <span class="hero-eyebrow">Riga / EU &middot; с 2026</span>
    </div>

    <div class="hero-center">
      <h1 class="hero-h1">Performance-<br />маркетинг<br />для ecommerce.<br />Без театра.</h1>
      <p class="hero-sub">
        Meta-реклама для брендов, которые выросли из самостоятельного запуска,
        но не готовы платить агентствам по €5k/мес за дашборды и созвоны.
      </p>
      <div class="hero-cta">
        <a class="btn btn-on-green" href={url('/contact')}>Получить аудит</a>
        <a class="hero-link tlink" href={url('/approach')}>Как мы работаем &rarr;</a>
      </div>
    </div>

    <div class="hero-bottom">
      <span>Senior-исполнение &middot; без агентского балласта</span>
      <span class="hero-bottom-right">Meta Ads &middot; ecommerce &amp; lead-gen</span>
    </div>
  </section>

  <!-- ══ 02 · PRINCIPLES ════════════════════════════════ -->
  <section class="principles">
    {principles.map((p) => (
      <div class="principle">
        <div class="principle-k">{p.k}</div>
        <div class="principle-v">{p.v}</div>
      </div>
    ))}
  </section>

  <!-- ══ 03 · POSITIONING ═══════════════════════════════ -->
  <section class="section pos">
    <div class="sec-label on-dark">01 — Позиция</div>
    <h2 class="pos-statement">Senior-исполнение<br />без агентского балласта.</h2>
    <p class="pos-body">
      Большинство SMB-брендов платят агентствам не за работу, а за инфраструктуру:
      аккаунт-менеджмент, созвоны, презентации, «стратегические сессии». Мы убрали
      всё, что не двигает цифру. Остался senior-уровень исполнения, прозрачные
      дашборды и письменный формат коммуникации. Это позволяет нам стоить меньше
      при том же качестве работы.
    </p>
  </section>

  <!-- ══ 04 · WHAT WE DO ════════════════════════════════ -->
  <section class="section services">
    <div class="sec-label">02 — Что мы делаем</div>
    <div class="services-grid">
      {services.map((s) => (
        <div class="service">
          <h3 class="service-name">{s.name}</h3>
          <p class="service-body">{s.body}</p>
        </div>
      ))}
    </div>
    <p class="services-note">
      Google Ads, TikTok, SEO, Amazon, инфлюенсеры — пока не делаем.
      Один канал, который знаем глубоко.
    </p>
    <a class="services-cta tlink" href={url('/services')}>Подробнее об услугах &rarr;</a>
  </section>

  <!-- ══ 05 · HOW WE WORK ═══════════════════════════════ -->
  <section class="section how">
    <div class="sec-label">03 — Как мы работаем</div>
    <div class="how-grid">
      {steps.map((s) => (
        <div class="step">
          <div class="step-n">{s.n}</div>
          <h3 class="step-t">{s.t}</h3>
          <p class="step-d">{s.d}</p>
        </div>
      ))}
    </div>
    <a class="how-cta tlink" href={url('/approach')}>Подробнее о подходе &rarr;</a>
  </section>

  <!-- ══ 06 · FIT ═══════════════════════════════════════ -->
  <section class="section fit">
    <div class="fit-col">
      <div class="fit-head fit-head-yes">Подходим</div>
      {fitYes.map((row) => (
        <div class="fit-row"><span class="fit-mark fit-mark-yes">&rarr;</span><span>{row}</span></div>
      ))}
    </div>
    <div class="fit-col">
      <div class="fit-head fit-head-no">Не подходим</div>
      {fitNo.map((row) => (
        <div class="fit-row fit-row-no"><span class="fit-mark fit-mark-no">&times;</span><span>{row}</span></div>
      ))}
    </div>
  </section>

  <!-- ══ 07 · РАЗБОР АККАУНТА (anonymized audit teardown) ══ -->
  <section class="section razbor" aria-labelledby="razbor-heading">
    <div class="sec-label on-dark">04 — Разбор</div>

    <h2 id="razbor-heading" class="razbor-lede">
      Анонимизированный аудит одного аккаунта.<br />
      <span class="razbor-lede-sub">EU&nbsp;косметика премиум · мульти-SKU Shopify · €8 тыс. в Meta · 4,5 месяца 2026.</span>
    </h2>

    <div class="razbor-hero">
      <div class="razbor-num" aria-label="43 процента">43<span class="razbor-num-pct">%</span></div>
      <div class="razbor-sub">продающего бюджета — впустую</div>
    </div>

    <div class="razbor-stats">
      <div class="razbor-stat">
        <div class="razbor-stat-n">0.33×</div>
        <div class="razbor-stat-t">Истинный ROAS</div>
        <div class="razbor-stat-d">vs&nbsp;1.09×, который показывал кабинет Meta. Безубыточность — 2.2×.</div>
      </div>
      <div class="razbor-stat">
        <div class="razbor-stat-n">6</div>
        <div class="razbor-stat-t">Мёртвых регионов</div>
        <div class="razbor-stat-d">ROAS&nbsp;≤&nbsp;0.12×. €2 тыс. потрачено — €184 вернулось.</div>
      </div>
      <div class="razbor-stat">
        <div class="razbor-stat-n">50<span class="razbor-stat-pct">%</span></div>
        <div class="razbor-stat-t">Появлений креатива — сломаны</div>
        <div class="razbor-stat-d">Одно видео во всех плейсментах. В&nbsp;ленте — обрезанные головы. В&nbsp;Stories — пустые поля.</div>
      </div>
    </div>

    <button
      class="razbor-toggle"
      type="button"
      id="razbor-toggle"
      aria-expanded="false"
      aria-controls="razbor-content"
    >
      <span class="razbor-toggle-label">Развернуть разбор полностью</span>
      <span class="razbor-toggle-arrow" aria-hidden="true">↓</span>
    </button>

    <div id="razbor-content" class="razbor-content" hidden>

      <!-- 01 · Где деньги исчезают -->
      <div class="razbor-block">
        <div class="razbor-block-head">
          <span class="razbor-block-n">01</span>
          <h3 class="razbor-block-t">Где деньги исчезают</h3>
        </div>
        <p class="razbor-block-lede">Из €8 218 потраченных в Meta за период бюджет дробится на три потока:</p>
        <div class="razbor-bars">
          <div class="razbor-bar">
            <div class="razbor-bar-label">
              <span class="razbor-bar-amount">€3 991 · 49%</span>
              <span class="razbor-bar-name">Продающие кампании с заказами</span>
            </div>
            <div class="razbor-bar-track"><div class="razbor-bar-fill" style="width:49%;background:var(--sage);"></div></div>
            <div class="razbor-bar-note">49 заказов на €2 720</div>
          </div>
          <div class="razbor-bar razbor-bar-bad">
            <div class="razbor-bar-label">
              <span class="razbor-bar-amount">€2 968 · 36%</span>
              <span class="razbor-bar-name">Продающие кампании · 0 заказов</span>
            </div>
            <div class="razbor-bar-track"><div class="razbor-bar-fill" style="width:36%;background:var(--bronze);"></div></div>
            <div class="razbor-bar-note">Главная утечка бюджета · крупнейший резерв роста</div>
          </div>
          <div class="razbor-bar">
            <div class="razbor-bar-label">
              <span class="razbor-bar-amount">€1 259 · 15%</span>
              <span class="razbor-bar-name">Охватные кампании · офлайн-магазины</span>
            </div>
            <div class="razbor-bar-track"><div class="razbor-bar-fill" style="width:15%;background:rgba(255,255,255,0.4);"></div></div>
            <div class="razbor-bar-note">Офлайн-события не настроены — эффект не измеряется</div>
          </div>
        </div>
      </div>

      <!-- 02 · Два табло -->
      <div class="razbor-block">
        <div class="razbor-block-head">
          <span class="razbor-block-n">02</span>
          <h3 class="razbor-block-t">Два табло. Реальность — между ними.</h3>
        </div>
        <p class="razbor-block-lede">Meta показывает свой ROAS. Shopify показывает свой. Оба ниже порога безубыточности.</p>
        <div class="razbor-boards">
          <div class="razbor-board">
            <div class="razbor-board-label">Что говорит Meta</div>
            <div class="razbor-board-n">1.09×</div>
            <div class="razbor-board-detail">118 заказов · €8 995 ценности конверсий</div>
          </div>
          <div class="razbor-board razbor-board-real">
            <div class="razbor-board-label">Что подтверждает Shopify</div>
            <div class="razbor-board-n">0.33×</div>
            <div class="razbor-board-detail">49 заказов · €2 720 выручки</div>
          </div>
        </div>
        <p class="razbor-block-conclusion">ROAS рос два месяца, достиг пика 1.31× в марте и с тех пор снижается до 0.79× в мае. Усталость креатива — наиболее вероятная причина.</p>
      </div>

      <!-- 03 · Аудитория -->
      <div class="razbor-block">
        <div class="razbor-block-head">
          <span class="razbor-block-n">03</span>
          <h3 class="razbor-block-t">Остановка 1 · Аудитория</h3>
        </div>
        <p class="razbor-block-lede">Meta сам распределяет бюджет по возрасту. Решает не клик, а превращение корзины в покупку.</p>
        <div class="razbor-table-wrap">
          <table class="razbor-table">
            <thead>
              <tr><th>Возраст</th><th class="num">Бюджет</th><th class="num">CTR</th><th class="num">ROAS</th><th>Вывод</th></tr>
            </thead>
            <tbody>
              <tr><td>18–24</td><td class="num">€1 445</td><td class="num">5.4%</td><td class="num">1.17×</td><td>Минимизировать</td></tr>
              <tr><td>25–34</td><td class="num">€1 827</td><td class="num">5.3%</td><td class="num">1.27×</td><td>Сохранить</td></tr>
              <tr class="razbor-row-bad"><td>35–44</td><td class="num">€2 422</td><td class="num">6.3%</td><td class="num">0.85×</td><td>Диагностировать — 715 корзин, 3.2% конверсия</td></tr>
              <tr class="razbor-row-good"><td>45–54</td><td class="num">€2 263</td><td class="num">5.3%</td><td class="num">1.81×</td><td>Усилить — скрытый чемпион</td></tr>
              <tr><td>55–64</td><td class="num">€951</td><td class="num">3.7%</td><td class="num">0.60×</td><td>Отключить</td></tr>
              <tr><td>65+</td><td class="num">€588</td><td class="num">3.2%</td><td class="num">0.35×</td><td>Отключить</td></tr>
            </tbody>
          </table>
        </div>
        <p class="razbor-block-conclusion">€926 на мужскую аудиторию: CTR 0.21%, около 9 покупок. Исключение мужчин — действие в один клик, возвращает почти весь бюджет.</p>
      </div>

      <!-- 04 · География -->
      <div class="razbor-block">
        <div class="razbor-block-head">
          <span class="razbor-block-n">04</span>
          <h3 class="razbor-block-t">Остановка 2 · География</h3>
        </div>
        <p class="razbor-block-lede">Шесть регионов с ROAS&nbsp;≤&nbsp;0.12× получили €2 021 — вернули €184. Один регион в плюсе.</p>
        <div class="razbor-table-wrap">
          <table class="razbor-table">
            <thead>
              <tr><th>Регион</th><th class="num">Расход</th><th class="num">Возврат</th><th class="num">ROAS</th><th>Вывод</th></tr>
            </thead>
            <tbody>
              <tr class="razbor-row-good"><td>Регион в плюсе</td><td class="num">€179</td><td class="num">€300</td><td class="num">1.68×</td><td>Масштабировать</td></tr>
              <tr><td>Столица</td><td class="num">€4 803</td><td class="num">€1 385</td><td class="num">0.29×</td><td>Таргетировать прицельно (видимый ROAS занижен — охватные кампании здесь)</td></tr>
              <tr class="razbor-row-bad"><td>6 мёртвых регионов</td><td class="num">€2 021</td><td class="num">€184</td><td class="num">≤0.12×</td><td>Отключить · перенести бюджет в столицу</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- 05 · Креатив -->
      <div class="razbor-block">
        <div class="razbor-block-head">
          <span class="razbor-block-n">05</span>
          <h3 class="razbor-block-t">Остановка 3 · Креатив</h3>
        </div>
        <p class="razbor-block-lede">Одно видео крутится во всех плейсментах сразу — у ленты и Stories разные пропорции. Один ассет не может выглядеть правильно везде.</p>
        <ul class="razbor-list">
          <li><strong>50% появлений в ленте — с дефектом.</strong> Обрезанные головы в Facebook Feed, пустые поля по бокам в Stories.</li>
          <li><strong>Карусель ведёт на главную.</strong> Клик по конкретному товару открывает не его, а главную страницу. Часть посетителей уходит — клик оплачен, продажа потеряна.</li>
          <li><strong>AI-улучшения Meta включены.</strong> Функции, которые непредсказуемо меняют готовый креатив. Для бренд-контента отключают.</li>
          <li class="razbor-list-good"><strong>Эталон уже в аккаунте.</strong> Одно объявление: 13 покупок · ROAS 1.81× · CTR 3.01%. Формат Advantage+ Shopping, один товар-герой. Норма, на которую нужно равняться.</li>
        </ul>
      </div>

      <!-- 06 · План -->
      <div class="razbor-block razbor-block-plan">
        <div class="razbor-block-head">
          <span class="razbor-block-n">06</span>
          <h3 class="razbor-block-t">План · Этап 1 · в рамках того же бюджета</h3>
        </div>
        <ol class="razbor-plan">
          <li>UTM-метки на всю рекламу Meta — половина продаж снова станет видимой</li>
          <li>Отключить 65+, 55–64 и мужчин; группу 18–24 минимизировать</li>
          <li>Сфокусироваться на столице; шесть мёртвых регионов отключить</li>
          <li>Видео в двух форматах (квадрат + вертикаль); отключить AI-улучшения</li>
          <li>Меньше кампаний, дольше срок жизни, адекватный дневной бюджет</li>
          <li>Перевести оптимизацию с «Initiate Checkout» на «Purchase»</li>
          <li>Карусель: каждая карточка ведёт на страницу своего товара</li>
          <li>Пилот каталожной рекламы — самый дешёвый формат для e-commerce</li>
        </ol>
        <p class="razbor-block-conclusion">Перераспределение не сделает Meta прибыльной мгновенно: порог безубыточности 2.2×, лучший сегмент сейчас 1.81×. Этап 1 останавливает потери и концентрирует бюджет; полная прибыльность канала потребует работы над конверсией сайта и средним чеком.</p>
      </div>

      <!-- Disclaimer -->
      <p class="razbor-disclaimer">
        Имя бренда и продуктов скрыто с разрешения клиента. Числа округлены минимально, чтобы сохранить структурную точность. Период: январь — май 2026.
      </p>

      <!-- CTA -->
      <div class="razbor-cta">
        <p class="razbor-cta-text">Хотите такой же разбор для вашего аккаунта?</p>
        <a class="btn razbor-cta-btn" href={url('/contact')}>Получить аудит &rarr;</a>
      </div>

    </div>
  </section>

  <!-- ══ 08 · FOUNDERS ══════════════════════════════════ -->
  <section class="section founders">
    <div class="sec-label">05 — Кто мы</div>
    <div class="founders-grid">
      {founders.map((f) => (
        <div class="founder">
          <div class="founder-mark">{f.initial}</div>
          <div class="founder-head">
            <span class="founder-name">{f.name}</span>
            <span class="founder-role">{f.role}</span>
          </div>
          <p class="founder-body">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 09 · CLOSING CTA ═══════════════════════════════ -->
  <section class="section closing">
