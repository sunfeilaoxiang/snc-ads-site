---
/**
 * Cases page — English. Methodology only. Adapted for English-speaking founders.
 * Keep structure + styles in sync with src/pages/cases.astro.
 */
import Base from '../../layouts/Base.astro';
import CtaClosing from '../../components/CtaClosing.astro';

const measure = [
  {
    name: 'Ecommerce',
    body: 'We set target ROAS off your margin, AOV, conversion rate and payback window. ROAS on its own means nothing — a 4× can be a win or a loss depending on the economics.',
  },
  {
    name: 'Lead-gen',
    body: 'Cost per lead and lead quality, judged together. A cheap lead that never converts isn’t a result. Closing the lead into a sale is partly your job — and we’ll say so.',
  },
];

const structure = [
  { t: 'Client profile', d: 'Vertical, market, size. Anonymized until the client clears the name.' },
  { t: 'The problem',    d: 'What was broken or underperforming. Specific — no "market headwinds".' },
  { t: 'What we did',    d: 'The actual moves on the account. Not "developed a strategy".' },
  { t: 'The numbers',    d: 'Before and after, with the basis of calculation shown — not a figure ripped out of context.' },
  { t: 'Timeframe',      d: 'How long it took. A number with no timeframe means nothing.' },
];
---

<Base
  title="Cases — SNC Advertising | How we measure results"
  description="SNC Advertising launched in 2026. Case studies land as the first clients clear NDA. Here's how we measure results and what every case study will contain."
>
  <section class="page-hero">
    <div class="page-hero-label">Cases</div>
    <h1 class="page-hero-h1">Case studies — in progress.</h1>
    <p class="page-hero-lede">
      SNC Advertising launched in 2026. Anonymized case studies will land here as the
      first clients clear NDA. For now — a straight account of how we measure
      results and what every case study will contain.
    </p>
  </section>

  <!-- How we measure -->
  <section class="section section-dark">
    <div class="sec-label on-dark">01 — How we measure results</div>
    <div class="measure-grid">
      {measure.map((m) => (
        <div class="measure">
          <h3 class="measure-name">{m.name}</h3>
          <p class="measure-body muted-dark">{m.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- What a case study contains -->
  <section class="section section-light">
    <div class="sec-label">02 — What every case study will contain</div>
    <div class="struct">
      {structure.map((s) => (
        <div class="struct-row">
          <h3 class="struct-t">{s.t}</h3>
          <p class="struct-d muted-light">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Reporting -->
  <section class="section section-warm">
    <div class="sec-label">03 — What the work looks like</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      The transparency shows up long before a case study does.
    </h2>
    <p class="lede muted-light" style="margin-top:20px;">
      A dashboard with the numbers from day one. Written updates.
      A monthly review of what worked and what's next. A case study is just
      that work, summed up over a period.
    </p>
  </section>

  <!-- Honest note -->
  <section class="section section-forest">
    <div class="sec-label on-dark">04 — Straight talk</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      We don't borrow other people's logos or results.
    </h2>
    <p class="lede muted-dark" style="margin-top:20px;">
      The case studies here will be real — real numbers from real SNC clients.
      Want to see what the founders have done before? Ask on the audit call and
      we'll walk you through it.
    </p>
  </section>

  <CtaClosing
    statement="Want to see<br />the numbers?"
    body="On the audit call we'll walk through past results and review your account."
  />
</Base>

<style>
  .measure-grid {
    margin-top: 28px;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--dim); border: 1px solid var(--dim);
  }
  .measure { background: var(--nearblack); padding: 28px 24px; }
  .measure-name { font-size: 15px; font-weight: 600; color: var(--sage); }
  .measure-body { margin-top: 12px; font-size: 14px; line-height: 1.75; }

  .struct { margin-top: 28px; }
  .struct-row {
    display: grid; grid-template-columns: 200px 1fr; gap: 24px;
    padding: 20px 0; border-top: 1px solid var(--dim-light);
  }
  .struct-row:last-child { border-bottom: 1px solid var(--dim-light); }
  .struct-t { font-size: 15px; font-weight: 600; color: var(--green); }
  .struct-d { font-size: 14px; line-height: 1.75; }

  @media (max-width: 760px) {
    .measure-grid { grid-template-columns: 1fr; }
    .struct-row { grid-template-columns: 1fr; gap: 6px; }
  }
</style>
