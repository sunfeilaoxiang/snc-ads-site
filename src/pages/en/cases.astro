---
/**
 * Cases page — English. Methodology only. Faithful translation of
 * src/pages/cases.astro. Keep structure + styles in sync with the RU version.
 */
import Base from '../../layouts/Base.astro';
import CtaClosing from '../../components/CtaClosing.astro';

const measure = [
  {
    name: 'Ecommerce',
    body: 'We derive target ROAS from your margin, AOV, conversion rate and payback window. ROAS detached from those numbers means nothing — "4×" can be a failure or a success depending on the economics.',
  },
  {
    name: 'Lead-gen',
    body: 'Target cost per lead and lead quality — together, not separately. A cheap useless lead does not count as a result. Converting a lead into a sale is partly your job, and we say so plainly.',
  },
];

const structure = [
  { t: 'Client profile', d: 'Vertical, market, size. Anonymized — until the client allows the name.' },
  { t: 'The problem',    d: 'What was broken or under-delivered. Specific, no "market challenges".' },
  { t: 'What we did',    d: 'Concrete actions on the account. Not "developed a strategy".' },
  { t: 'Metrics',        d: 'Before and after. With the basis of calculation shown, not a number ripped out of context.' },
  { t: 'Timeframe',      d: 'How long it took. Without a timeframe a number means nothing.' },
];
---

<Base
  title="Cases — SNC Media | How we measure results"
  description="SNC Media launched in 2026. Cases will appear as the first clients come out of NDA. Here is how we measure results and what each case study will contain."
>
  <section class="page-hero">
    <div class="page-hero-label">Cases</div>
    <h1 class="page-hero-h1">Cases — in progress.</h1>
    <p class="page-hero-lede">
      SNC Media launched in 2026. Anonymized cases will appear here as the
      first clients come out of NDA. For now — an honest account of how we
      measure results and what each case study will contain.
    </p>
  </section>

  <!-- How we measure -->
  <section class="section section-dark">
    <div class="sec-label on-dark">01 — How we measure results</div>
    <div class="measure-grid">
      {measure.map((m) => (
        <div class="measure">
          <h3 class="measure-name">{m.name}</h3>
          <p class="measure-body muted-dark">{m.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- What a case study contains -->
  <section class="section section-light">
    <div class="sec-label">02 — What a case study will contain</div>
    <div class="struct">
      {structure.map((s) => (
        <div class="struct-row">
          <h3 class="struct-t">{s.t}</h3>
          <p class="struct-d muted-light">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Reporting -->
  <section class="section section-warm">
    <div class="sec-label">03 — This is what the work looks like</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      Transparency is visible before a case study even exists.
    </h2>
    <p class="lede muted-light" style="margin-top:20px;">
      A dashboard with the numbers from day one. A written update every Friday.
      A monthly review of what worked and what is next. A case study is simply
      the summary of work like that over a period.
    </p>
  </section>

  <!-- Honest note -->
  <section class="section section-forest">
    <div class="sec-label on-dark">04 — Honest</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      We don't publish other people's logos or other people's results.
    </h2>
    <p class="lede muted-dark" style="margin-top:20px;">
      The cases on this page will appear real — with real numbers from real
      SNC clients. Want to see results from the founders' past projects — ask
      during the audit, we'll show you in person.
    </p>
  </section>

  <CtaClosing
    statement="Want to see<br />the numbers?"
    body="During the audit we'll show results from past projects and review your account."
  />
</Base>

<style>
  .measure-grid {
    margin-top: 28px;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--dim); border: 1px solid var(--dim);
  }
  .measure { background: var(--nearblack); padding: 28px 24px; }
  .measure-name { font-size: 15px; font-weight: 600; color: var(--sage); }
  .measure-body { margin-top: 12px; font-size: 14px; line-height: 1.75; }

  .struct { margin-top: 28px; }
  .struct-row {
    display: grid; grid-template-columns: 200px 1fr; gap: 24px;
    padding: 20px 0; border-top: 1px solid var(--dim-light);
  }
  .struct-row:last-child { border-bottom: 1px solid var(--dim-light); }
  .struct-t { font-size: 15px; font-weight: 600; color: var(--green); }
  .struct-d { font-size: 14px; line-height: 1.75; }

  @media (max-width: 760px) {
    .measure-grid { grid-template-columns: 1fr; }
    .struct-row { grid-template-columns: 1fr; gap: 6px; }
  }
</style>
