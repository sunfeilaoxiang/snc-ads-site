---
/**
 * Services page — English. Adapted for English-speaking founders.
 * Keep structure + styles in sync with src/pages/services.astro.
 */
import Base from '../../layouts/Base.astro';
import CtaClosing from '../../components/CtaClosing.astro';

const included = [
  { t: 'Account audit',      d: 'Tracking, structure, creative. Where the budget is leaking.' },
  { t: 'Campaign setup',     d: 'Account structure, full website tracking setup from scratch, catalogs and feeds.' },
  { t: 'Creative testing',   d: 'Briefs, rotation, iteration. Calls made on data, not taste.' },
  { t: 'Daily optimization', d: 'Budgets, bids, scaling winners, cutting losers.' },
  { t: 'Weekly update',      d: 'A written report — what got done, what’s next.' },
  { t: 'Monthly report',     d: 'The ad P&L. What worked, what didn’t, the plan ahead.' },
  { t: 'Strategy call',      d: 'Once a month, 30 minutes — if you want it.' },
];

const lines = [
  {
    name: 'Ecommerce',
    body: 'Catalogs, feeds, Advantage+ Shopping, retargeting. We set a target ROAS off your margin, AOV, conversion rate and payback window — ROAS on its own, without those numbers, tells you nothing.',
  },
  {
    name: 'Lead-gen',
    body: 'Lead campaigns for service businesses. We optimize for cost per lead and lead quality — not clicks. What happens after the lead — closing the sale — is partly on you, and we’ll say that upfront.',
  },
];

const promise = [
  'Written updates',
  'Dashboard access from day one',
  'Audit and benchmarks within 7 days of kickoff',
  'A monthly call — optional, 30 minutes',
  "30 days' notice to cancel",
];

const noPromise = [
  'A guaranteed ROAS',
  'A guaranteed timeline ("results in 14 days")',
  "A lead or sales number before we've seen the account",
  '24/7 support or same-day replies',
  'Free trials or money-back guarantees',
];
---

<Base
  title="Services — SNC Advertising | Meta advertising for ecommerce"
  description="Meta paid media for ecommerce and lead-gen. One channel, done properly. What's included, the two tracks, and what we will and won't promise."
>
  <section class="page-hero">
    <div class="page-hero-label">Services</div>
    <h1 class="page-hero-h1">Meta advertising.<br />One channel, done properly.</h1>
    <p class="page-hero-lede">
      We do one thing, at a senior level. No full-service menu — just Meta
      paid media, run like an operating system.
    </p>
  </section>

  <!-- What's included -->
  <section class="section section-dark">
    <div class="sec-label on-dark">01 — What's included</div>
    <div class="incl-list">
      {included.map((i) => (
        <div class="incl">
          <h3 class="incl-t">{i.t}</h3>
          <p class="incl-d muted-dark">{i.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Two tracks -->
  <section class="section section-warm">
    <div class="sec-label">02 — Two tracks</div>
    <p class="lede muted-light" style="margin-top:16px;">
      Pricing tracks complexity. Ecommerce usually takes more work than
      lead-gen, and costs more. We give you the exact figure after a short
      call — it's deliberately not on the site.
    </p>
    <div class="lines-grid">
      {lines.map((l) => (
        <div class="line">
          <h3 class="line-name">{l.name}</h3>
          <p class="line-body muted-light">{l.body}</p>
        </div>
      ))}
    </div>
    <div class="creative">
      <h3 class="line-name">Creative — optional</h3>
      <p class="line-body muted-light">
        Platform-specific briefs and freelance coordination. Production is
        billed separately — never baked into the retainer.
      </p>
    </div>
  </section>

  <!-- What we don't do -->
  <section class="section section-forest">
    <div class="sec-label on-dark">03 — What we don't do</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      Google Ads, TikTok, SEO, Amazon, influencers — not yet.
    </h2>
    <p class="lede muted-dark" style="margin-top:20px;">
      One channel run properly beats five run at a mediocre level. We'll add
      services once the Meta process is fully dialled in — and only as an
      add-on for existing clients, not a menu for everyone.
    </p>
  </section>

  <!-- Promise / don't promise -->
  <section class="section section-dark">
    <div class="sec-label on-dark">04 — Straight talk on expectations</div>
    <div class="promise-grid">
      <div class="promise-col">
        <div class="promise-head promise-head-yes">What we promise</div>
        {promise.map((p) => (
          <div class="promise-row"><span class="pm pm-yes">&rarr;</span><span>{p}</span></div>
        ))}
      </div>
      <div class="promise-col">
        <div class="promise-head promise-head-no">What we don't</div>
        {noPromise.map((p) => (
          <div class="promise-row muted-dark"><span class="pm pm-no">&times;</span><span>{p}</span></div>
        ))}
      </div>
    </div>
    <p class="promise-note muted-dark">
      We guarantee what we control: setup quality, test volume, weekly
      optimization, transparent reporting. The result target is set together,
      with a 60–90 day window to judge it.
    </p>
  </section>

  <CtaClosing
    statement="Are we a fit<br />for your business?"
    body="Send us a note — we'll look at the account and give you a straight answer. If we're not a fit, we'll say so."
  />
</Base>

<style>
  .incl-list { margin-top: 28px; }
  .incl {
    display: grid; grid-template-columns: 240px 1fr; gap: 24px;
    padding: 20px 0; border-top: 1px solid var(--dim);
  }
  .incl:last-child { border-bottom: 1px solid var(--dim); }
  .incl-t { font-size: 15px; font-weight: 600; color: var(--sage); }
  .incl-d { font-size: 14px; line-height: 1.7; }

  .lines-grid {
    margin-top: 28px;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--dim-light); border: 1px solid var(--dim-light);
  }
  .line { background: var(--offwhite); padding: 28px 24px; }
  .line-name { font-size: 15px; font-weight: 600; color: var(--green); }
  .line-body { margin-top: 12px; font-size: 14px; line-height: 1.75; }
  .creative {
    margin-top: 1px; background: var(--offwhite);
    border: 1px solid var(--dim-light); padding: 28px 24px;
  }

  .promise-grid {
    margin-top: 28px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
  }
  .promise-col { padding: 0 32px; }
  .promise-col:first-child { border-right: 1px solid var(--dim); padding-left: 0; }
  .promise-head {
    font-size: 11px; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; margin-bottom: 18px;
  }
  .promise-head-yes { color: var(--sage); }
  .promise-head-no  { color: var(--bronze); }
  .promise-row {
    display: flex; gap: 12px; align-items: flex-start;
    font-size: 14px; line-height: 1.7; margin-bottom: 12px;
  }
  .pm { flex-shrink: 0; }
  .pm-yes { color: var(--sage); }
  .pm-no  { color: var(--bronze); }
  .promise-note {
    margin-top: 28px; max-width: 640px;
    font-size: 14px; line-height: 1.8;
  }

  @media (max-width: 760px) {
    .incl { grid-template-columns: 1fr; gap: 6px; }
    .lines-grid { grid-template-columns: 1fr; }
    .promise-grid { grid-template-columns: 1fr; gap: 28px; }
    .promise-col { padding: 0; }
    .promise-col:first-child {
      border-right: 0; border-bottom: 1px solid var(--dim); padding-bottom: 24px;
    }
  }
</style>
