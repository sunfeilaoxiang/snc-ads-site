---
/**
 * Cases page — methodology only (decided 2026-05-17).
 * SNC has no client cases yet. This page is honest about that and shows
 * how results are measured + what a case study will contain. No fake
 * logos, no borrowed results.
 */
import Base from '../layouts/Base.astro';
import CtaClosing from '../components/CtaClosing.astro';

const measure = [
  {
    name: 'Ecommerce',
    body: 'Целевой ROAS выводим из вашей маржи, AOV, конверсии и окна окупаемости. ROAS в отрыве от этих цифр не значит ничего — «4×» может быть провалом или успехом в зависимости от экономики.',
  },
  {
    name: 'Lead-gen',
    body: 'Целевая стоимость лида и его качество — вместе, не по отдельности. Дешёвый бесполезный лид не считается результатом. Конверсия лида в продажу — частично ваша зона, и мы говорим об этом прямо.',
  },
];

const structure = [
  { t: 'Профиль клиента', d: 'Вертикаль, рынок, размер. Анонимно — до тех пор, пока клиент не разрешит имя.' },
  { t: 'Задача',          d: 'Что было сломано или недополучено. Конкретно, без «вызовов рынка».' },
  { t: 'Что сделали',     d: 'Конкретные действия по аккаунту. Не «разработали стратегию».' },
  { t: 'Метрики',         d: 'До и после. С указанием базы расчёта, не вырванное число.' },
  { t: 'Срок',            d: 'За сколько. Без срока цифра не значит ничего.' },
];
---

<Base
  title="Кейсы — SNC Media | Как мы измеряем результат"
  description="SNC Media запущена в 2026. Кейсы появятся по мере выхода первых клиентов из NDA. Здесь — как мы измеряем результат и из чего будет состоять каждый кейс."
>
  <section class="page-hero">
    <div class="page-hero-label">Кейсы</div>
    <h1 class="page-hero-h1">Кейсы — в работе.</h1>
    <p class="page-hero-lede">
      SNC Media запущена в 2026. Анонимизированные кейсы появятся здесь по мере
      выхода первых клиентов из NDA. Пока — честно о том, как мы измеряем
      результат и из чего будет состоять каждый кейс.
    </p>
  </section>

  <!-- Как измеряем -->
  <section class="section section-dark">
    <div class="sec-label on-dark">01 — Как мы измеряем результат</div>
    <div class="measure-grid">
      {measure.map((m) => (
        <div class="measure">
          <h3 class="measure-name">{m.name}</h3>
          <p class="measure-body muted-dark">{m.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Из чего состоит кейс -->
  <section class="section section-light">
    <div class="sec-label">02 — Из чего будет состоять кейс</div>
    <div class="struct">
      {structure.map((s) => (
        <div class="struct-row">
          <h3 class="struct-t">{s.t}</h3>
          <p class="struct-d muted-light">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Отчётность -->
  <section class="section section-warm">
    <div class="sec-label">03 — Так выглядит работа</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      Прозрачность видно ещё до того, как появится кейс.
    </h2>
    <p class="lede muted-light" style="margin-top:20px;">
      Дашборд с цифрами с первого дня. Письменный апдейт по пятницам. Ежемесячный
      обзор с разбором, что сработало и что дальше. Кейс — это просто итог такой
      работы за период.
    </p>
  </section>

  <!-- Честная нота -->
  <section class="section section-forest">
    <div class="sec-label on-dark">04 — Честно</div>
    <h2 class="statement" style="margin-top:24px;max-width:680px;">
      Мы не публикуем чужие логотипы и чужие результаты.
    </h2>
    <p class="lede muted-dark" style="margin-top:20px;">
      Кейсы на этой странице появятся настоящими — с реальными цифрами реальных
      клиентов SNC. Хотите посмотреть результаты прошлых проектов основателей —
      спросите на аудите, покажем лично.
    </p>
  </section>

  <CtaClosing
    statement="Хотите увидеть<br />цифры?"
    body="На аудите покажем результаты прошлых проектов и разберём ваш аккаунт."
  />
</Base>

<style>
  .measure-grid {
    margin-top: 28px;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--dim); border: 1px solid var(--dim);
  }
  .measure { background: var(--nearblack); padding: 28px 24px; }
  .measure-name { font-size: 15px; font-weight: 600; color: var(--sage); }
  .measure-body { margin-top: 12px; font-size: 14px; line-height: 1.75; }

  .struct { margin-top: 28px; }
  .struct-row {
    display: grid; grid-template-columns: 200px 1fr; gap: 24px;
    padding: 20px 0; border-top: 1px solid var(--dim-light);
  }
  .struct-row:last-child { border-bottom: 1px solid var(--dim-light); }
  .struct-t { font-size: 15px; font-weight: 600; color: var(--green); }
  .struct-d { font-size: 14px; line-height: 1.75; }

  @media (max-width: 760px) {
    .measure-grid { grid-template-columns: 1fr; }
    .struct-row { grid-template-columns: 1fr; gap: 6px; }
  }
</style>
