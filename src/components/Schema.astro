---
/**
 * Organization JSON-LD (schema.org) for AI/entity recognition + rich results.
 * Sitewide via Base.astro. Locale-aware description; everything else is stable.
 * No pricing is exposed here — it's quoted in conversation (brand rule).
 */
import { type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const description = locale === 'en'
  ? 'SNC Advertising is a performance marketing agency specialising in Meta (Facebook and Instagram) advertising for ecommerce and lead-generation brands. Senior execution, written reporting, async by default — no agency overhead. Based in Riga, serving the EU.'
  : 'SNC Advertising — агентство performance-маркетинга: реклама в Meta (Facebook и Instagram) для ecommerce и lead-gen брендов. Senior-исполнение, письменная отчётность, асинхронный формат — без агентского балласта. Рига, работаем по всему ЕС.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://sncads.com/#organization',
  name: 'SNC Advertising',
  alternateName: 'SNC Ads',
  url: 'https://sncads.com/',
  description,
  email: 'dmitrijs@sncads.com',
  foundingDate: '2026',
  slogan: locale === 'en' ? 'Performance marketing for ecommerce. No agency theatre.' : 'Performance-маркетинг для ecommerce. Без театра.',
  areaServed: { '@type': 'Place', name: 'European Union' },
  knowsAbout: [
    'Meta Ads',
    'Facebook advertising',
    'Instagram advertising',
    'performance marketing',
    'ecommerce advertising',
    'lead generation',
    'Advantage+ Shopping',
    'Meta Pixel',
    'Conversions API',
  ],
  founder: [
    { '@type': 'Person', name: 'Nikita', jobTitle: 'Meta / Ads' },
    { '@type': 'Person', name: 'Dmitrijs', jobTitle: 'CCO / Finance' },
  ],
  makesOffer: [
    {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Meta Ads for ecommerce',
        serviceType: 'Performance marketing',
        description: 'Campaign launch, creative testing, daily optimisation, full website tracking setup, catalogs, Advantage+ Shopping and retargeting for ecommerce brands.',
      },
    },
    {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Meta Ads for lead generation',
        serviceType: 'Performance marketing',
        description: 'Lead campaigns for service businesses, optimised for cost per lead and lead quality.',
      },
    },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'dmitrijs@sncads.com',
    contactType: 'sales',
    availableLanguage: ['Russian', 'English'],
  },
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
