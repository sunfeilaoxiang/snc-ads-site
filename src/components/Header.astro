---
/**
 * Site header — logo, nav, language switcher, CTA. Locale-aware.
 * Below 760px the nav collapses into a hamburger → full-screen overlay.
 *
 * "Cases / Кейсы" is intentionally NOT in the primary nav — it's a methodology
 * page with no client cases yet. It stays reachable from the footer and the
 * mobile overlay.
 */
import { localizedUrl, logicalPath } from '../lib/links';
import { ui, type Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'ru') as Locale;
const t = ui[locale];
const otherLocale: Locale = locale === 'en' ? 'ru' : 'en';
const switchHref = localizedUrl(logicalPath(Astro.url.pathname), otherLocale);
const u = (p: string) => localizedUrl(p, locale);
---

<header class="hdr" id="site-header">
  <a class="hdr-logo" href={u('/')}>
    <span class="hdr-mark" aria-hidden="true">S</span>
    <span class="hdr-word">SNC<span class="hdr-word-sub"> Advertising</span></span>
  </a>

  <nav class="hdr-nav" aria-label={t.navAria}>
    {t.nav.map((item) => (
      <a class="hdr-nav-link tlink" href={u(item.path)}>{item.label}</a>
    ))}
  </nav>

  <div class="hdr-right">
    <a class="hdr-lang" href={switchHref} aria-label={t.langAria}>{t.langLabel}</a>
    <a class="hdr-cta" href={u('/contact')}>{t.cta}</a>
  </div>

  <button
    class="hdr-burger"
    id="nav-toggle"
    aria-label={t.menuOpen}
    aria-expanded="false"
    aria-controls="mobile-nav"
  >
    <span></span><span></span><span></span>
  </button>
</header>

<!-- Mobile overlay menu -->
<div class="mnav" id="mobile-nav" hidden>
  <nav class="mnav-links" aria-label={t.mobileNavAria}>
    {t.nav.map((item) => (
      <a class="mnav-link" href={u(item.path)}>{item.label}</a>
    ))}
    <a class="mnav-link mnav-link-sub" href={u('/cases')}>{t.casesLabel}</a>
  </nav>
  <div class="mnav-foot">
    <a class="mnav-cta" href={u('/contact')}>{t.cta}</a>
    <a class="mnav-lang" href={switchHref} aria-label={t.langAria}>{t.langLabel}</a>
  </div>
</div>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 200;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--pad-x);
    background: var(--green);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.2s;
  }
  .hdr.scrolled { background: var(--nearblack); border-bottom-color: var(--dim); }

  .hdr-logo { display: flex; align-items: center; gap: 10px; }
  .hdr-mark {
    width: 26px; height: 26px;
    border: 2px solid var(--white);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 600; line-height: 1;
  }
  .hdr-word {
    font-size: 13px; font-weight: 600; letter-spacing: 0.15em;
    display: flex; align-items: baseline; gap: 6px;
  }
  .hdr-word-sub {
    font-size: 8px; font-weight: 400; letter-spacing: 0.16em;
    text-transform: uppercase; color: rgba(255, 255, 255, 0.8);
  }

  .hdr-nav { display: flex; gap: 28px; margin-left: auto; margin-right: 28px; }
  .hdr-nav-link {
    font-size: 11px; font-weight: 400; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(255, 255, 255, 0.75);
  }
  .hdr-nav-link:hover { color: var(--white); }

  .hdr-right { display: flex; align-items: center; gap: 18px; }
  .hdr-lang {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.65);
    padding: 4px 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .hdr-lang:hover { color: var(--white); border-bottom-color: rgba(255, 255, 255, 0.5); }

  .hdr-cta {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 9px 16px;
    border: 1px solid var(--white);
    transition: background 0.15s, color 0.15s;
  }
  .hdr-cta:hover { background: var(--white); color: var(--green); }

  /* ── Hamburger ──────────────────────────────── */
  .hdr-burger {
    display: none;
    width: 40px; height: 40px;
    background: transparent; border: 0; cursor: pointer;
    flex-direction: column; justify-content: center; align-items: flex-end;
    gap: 5px; padding: 8px;
  }
  .hdr-burger span {
    display: block; width: 22px; height: 2px;
    background: var(--white); transition: transform 0.2s, opacity 0.2s;
  }
  .hdr.menu-open .hdr-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hdr.menu-open .hdr-burger span:nth-child(2) { opacity: 0; }
  .hdr.menu-open .hdr-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile overlay ─────────────────────────── */
  .mnav {
    position: fixed;
    inset: 56px 0 0 0;
    z-index: 150;
    background: var(--green);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 0 var(--pad-x) 64px;
  }
  .mnav[hidden] { display: none; }
  .mnav-links { display: flex; flex-direction: column; gap: 4px; }
  .mnav-link {
    font-size: 32px; font-weight: 600; letter-spacing: 0.02em;
    color: var(--white);
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .mnav-link-sub { font-size: 22px; color: rgba(255, 255, 255, 0.6); }
  .mnav-foot {
    margin-top: 28px;
    display: flex; align-items: center; gap: 24px;
  }
  .mnav-cta {
    font-size: 13px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 16px 28px;
    background: var(--white); color: var(--green);
  }
  .mnav-lang {
    font-size: 13px; font-weight: 600; letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.7);
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 2px;
  }

  @media (max-width: 760px) {
    .hdr-nav, .hdr-right { display: none; }
    .hdr-burger { display: flex; }
  }
</style>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var toggle = document.getElementById('nav-toggle');
    var menu = document.getElementById('mobile-nav');
    if (!header || !toggle || !menu) return;

    function onScroll() {
      header.classList.toggle('scrolled', window.scrollY > 40);
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    var labelOpen = toggle.getAttribute('aria-label') || 'Menu';

    function setMenu(open) {
      menu.hidden = !open;
      header.classList.toggle('menu-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    }

    toggle.addEventListener('click', function () {
      setMenu(menu.hidden);
    });
    menu.addEventListener('click', function (e) {
      if (e.target && e.target.tagName === 'A') setMenu(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !menu.hidden) setMenu(false);
    });
  })();
</script>
