---
/**
 * Site footer — Deep Forest panel. Locale-aware.
 */
import { localizedUrl } from '../lib/links';
import { ui, type Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'ru') as Locale;
const t = ui[locale];
const u = (p: string) => localizedUrl(p, locale);
const year = new Date().getFullYear();

const cols = [t.footer.services, t.footer.company];
const contact = [
  { label: 'Telegram', href: 'https://t.me/sunnfeii' },
  { label: 'Email', href: 'mailto:dmitrijs@sncads.com' },
];
---

<footer class="ftr">
  <div class="ftr-top">
    <a class="ftr-logo" href={u('/')}>
      <span class="ftr-mark" aria-hidden="true">S</span>
      <span class="ftr-word">SNC Advertising</span>
    </a>

    <div class="ftr-cols">
      {cols.map((col) => (
        <div class="ftr-col">
          <div class="ftr-col-title">{col.title}</div>
          {col.links.map((link) => (
            <a class="ftr-link tlink" href={u(link.path)}>{link.label}</a>
          ))}
        </div>
      ))}
      <div class="ftr-col">
        <div class="ftr-col-title">{t.footer.contactTitle}</div>
        {contact.map((link) => (
          <a class="ftr-link tlink" href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </div>

  <hr class="ftr-rule" />

  <div class="ftr-bottom">
    <span>{t.footer.rights.replace('{year}', String(year))}</span>
    <span>IBM Plex Mono &middot; #1E4D3A</span>
  </div>
</footer>

<style>
  .ftr {
    background: var(--forest);
    padding: 48px var(--pad-x) 28px;
  }
  .ftr-top {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }

  .ftr-logo { display: flex; align-items: center; gap: 10px; }
  .ftr-mark {
    width: 28px; height: 28px;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
  }
  .ftr-word {
    font-size: 11px; font-weight: 600; letter-spacing: 0.15em;
    text-transform: uppercase; color: rgba(255, 255, 255, 0.6);
  }

  .ftr-cols { display: flex; gap: 56px; flex-wrap: wrap; }
  .ftr-col { display: flex; flex-direction: column; gap: 10px; }
  .ftr-col-title {
    font-size: 10px; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--sage);
    margin-bottom: 4px;
  }
  .ftr-link { font-size: 12px; color: rgba(255, 255, 255, 0.7); }
  .ftr-link:hover { color: var(--white); }

  .ftr-rule {
    height: 1px; border: 0;
    background: rgba(255, 255, 255, 0.08);
    margin: 36px 0 18px;
  }
  .ftr-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
    font-size: 10px; letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 640px) {
    .ftr-cols { gap: 32px; }
  }
</style>
