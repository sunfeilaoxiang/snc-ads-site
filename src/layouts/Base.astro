---
/**
 * Base layout — HTML shell, head, fonts, analytics slots, header + footer.
 *
 * Analytics: paste GA4 / Meta Pixel / TikTok Pixel / Yandex Metrica snippets
 * into the marked slots below. They are intentionally empty until the real
 * pixel IDs exist. See snc-media-site/CLAUDE.md.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { url } from '../lib/links';
import { ui, type Locale } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  /** Hide the sticky header (e.g. for a bare landing page). */
  bareHeader?: boolean;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = '/og-default.png',
  bareHeader = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const faviconHref = url('/favicon.svg');
const ogImageUrl = new URL(url(ogImage), Astro.site);
const locale = (Astro.currentLocale ?? 'ru') as Locale;
const consent = (ui[locale] ?? ui.ru).consent;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts — IBM Plex Mono, the only typeface -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;600&display=swap"
      rel="stylesheet"
    />

    {/* ── ANALYTICS — consent-gated. Nothing fires until the visitor
        clicks Accept on the banner. GA4 G-C480L71EX6 + Meta Pixel
        1857063391638735. CAPI is a later (server-side) step. ── */}
    <script is:inline>
      (function () {
        var GA4_ID = 'G-C480L71EX6';
        var PIXEL_ID = '1857063391638735';
        window.sncConsent = {
          load: function () {
            if (window.sncAnalyticsLoaded) return;
            window.sncAnalyticsLoaded = true;
            // GA4
            var ga = document.createElement('script');
            ga.async = true;
            ga.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
            document.head.appendChild(ga);
            window.dataLayer = window.dataLayer || [];
            window.gtag = function () { window.dataLayer.push(arguments); };
            window.gtag('js', new Date());
            window.gtag('config', GA4_ID);
            // Meta Pixel
            !function (f, b, e, v, n, t, s) {
              if (f.fbq) return;
              n = f.fbq = function () {
                n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
              };
              if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
              n.queue = []; t = b.createElement(e); t.async = !0; t.src = v;
              s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
            }(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
            window.fbq('init', PIXEL_ID);
            window.fbq('track', 'PageView');
          },
          accept: function () {
            try { localStorage.setItem('snc-consent', 'accepted'); } catch (e) {}
            this.load();
          },
          decline: function () {
            try { localStorage.setItem('snc-consent', 'declined'); } catch (e) {}
          },
          state: function () {
            try { return localStorage.getItem('snc-consent'); } catch (e) { return null; }
          }
        };
        if (window.sncConsent.state() === 'accepted') window.sncConsent.load();
      })();
    </script>
  </head>

  <body>
    {/* ── ANALYTICS BODY (noscript) SLOT ─────────────────────── */}

    {!bareHeader && <Header />}
    <main>
      <slot />
    </main>
    <Footer />

    {/* ── GDPR consent banner — gates the analytics loader above ── */}
    <div id="consent" class="consent" role="dialog" aria-label="Cookies" hidden>
      <p class="consent-text">{consent.text}</p>
      <div class="consent-actions">
        <button type="button" class="consent-btn consent-accept" id="consent-accept">{consent.accept}</button>
        <button type="button" class="consent-btn consent-decline" id="consent-decline">{consent.decline}</button>
      </div>
    </div>
    <script is:inline>
      (function () {
        var el = document.getElementById('consent');
        if (!el || !window.sncConsent) return;
        if (window.sncConsent.state()) return; // already accepted or declined
        el.hidden = false;
        document.getElementById('consent-accept').addEventListener('click', function () {
          window.sncConsent.accept(); el.hidden = true;
        });
        document.getElementById('consent-decline').addEventListener('click', function () {
          window.sncConsent.decline(); el.hidden = true;
        });
      })();
    </script>
  </body>
</html>

<style>
  .consent {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px 28px; flex-wrap: wrap;
    background: var(--nearblack);
    border-top: 1px solid var(--dim);
    padding: 16px clamp(20px, 5vw, 64px);
  }
  .consent[hidden] { display: none; }
  .consent-text {
    margin: 0; max-width: 760px;
    font-size: 12px; line-height: 1.6; color: rgba(255, 255, 255, 0.72);
  }
  .consent-actions { display: flex; gap: 10px; flex-shrink: 0; }
  .consent-btn {
    font-family: var(--font); font-size: 11px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 10px 18px; cursor: pointer;
    border: 1px solid var(--dim); background: transparent;
    color: rgba(255, 255, 255, 0.8); transition: all 0.15s;
  }
  .consent-accept { background: var(--green); border-color: var(--green); color: #fff; }
  .consent-accept:hover { background: #245a45; }
  .consent-decline:hover { border-color: var(--sage); color: #fff; }
</style>
