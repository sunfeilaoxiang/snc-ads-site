---
/**
 * Base layout — HTML shell, head, fonts, analytics slots, header + footer.
 *
 * Analytics: paste GA4 / Meta Pixel / TikTok Pixel / Yandex Metrica snippets
 * into the marked slots below. They are intentionally empty until the real
 * pixel IDs exist. See snc-media-site/CLAUDE.md.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { url } from '../lib/links';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  /** Hide the sticky header (e.g. for a bare landing page). */
  bareHeader?: boolean;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = '/og-default.png',
  bareHeader = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const faviconHref = url('/favicon.svg');
const ogImageUrl = new URL(url(ogImage), Astro.site);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts — IBM Plex Mono, the only typeface -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;600&display=swap"
      rel="stylesheet"
    />

    {/* ── ANALYTICS HEAD SLOT ──────────────────────────────────
        Paste GA4 + Meta Pixel + TikTok Pixel + Yandex Metrica
        snippets here once pixel IDs exist. Empty by design. */}
  </head>

  <body>
    {/* ── ANALYTICS BODY (noscript) SLOT ─────────────────────── */}

    {!bareHeader && <Header />}
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
