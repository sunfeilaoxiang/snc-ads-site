# .env.example — document what env vars this project needs.
# Real values go in .env (gitignored). NEVER put real secrets in this file.
#
# Copy this to .env locally and fill in real values:
#   cp .env.example .env
#
# When you add a new env var to the codebase, add a line here too —
# this file is the canonical inventory of every secret/config the app reads.

# === Application ===
# NODE_ENV=development

# === Database ===
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === Third-party APIs ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === Analytics / tracking ===
# META_PIXEL_ID=
# META_CAPI_TOKEN=
# GA4_MEASUREMENT_ID=
